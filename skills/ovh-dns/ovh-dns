#!/usr/bin/env python3
"""OVH DNS Management CLI — safe wrapper around the OVH API.

Only permits /domain/zone/* API paths. Auto-backs up before mutations.
Logs every mutation to ~/fang/reports/dns-mutations.jsonl.
"""

import argparse
import json
import os
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

import ovh

# ── Paths ────────────────────────────────────────────────────────────────────
OVH_CONF = Path.home() / "fang" / ".ovh.conf"
BACKUP_DIR = Path.home() / "fang" / "reports" / "dns-backups"
MUTATION_LOG = Path.home() / "fang" / "reports" / "dns-mutations.jsonl"

BACKUP_DIR.mkdir(parents=True, exist_ok=True)


# ── Helpers ──────────────────────────────────────────────────────────────────

def get_client():
    return ovh.Client(config_file=str(OVH_CONF))


def api_call(client, method, path, **kwargs):
    """Execute an OVH API call, enforcing /domain/zone/* scope."""
    if not path.startswith("/domain/zone/"):
        print(f"ERROR: blocked API path '{path}' — only /domain/zone/* is allowed.", file=sys.stderr)
        sys.exit(1)
    fn = getattr(client, method)
    return fn(path, **kwargs)


def log_mutation(domain, action, record_id=None, old_value=None, new_value=None):
    entry = {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "domain": domain,
        "action": action,
        "record_id": record_id,
        "old_value": old_value,
        "new_value": new_value,
    }
    with open(MUTATION_LOG, "a") as f:
        f.write(json.dumps(entry) + "\n")


def backup_domain(client, domain):
    """Dump all DNS records for a domain to a timestamped JSON file."""
    ids = api_call(client, "get", f"/domain/zone/{domain}/record")
    records = []
    for rid in ids:
        rec = api_call(client, "get", f"/domain/zone/{domain}/record/{rid}")
        records.append(rec)
    ts = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    path = BACKUP_DIR / f"{domain}-{ts}.json"
    with open(path, "w") as f:
        json.dump({"domain": domain, "timestamp": ts, "records": records}, f, indent=2)
    return path, records


def get_record_detail(client, domain, record_id):
    """Fetch a single record's details."""
    return api_call(client, "get", f"/domain/zone/{domain}/record/{record_id}")


def format_record(rec):
    """Pretty-print one DNS record."""
    return (
        f"  id={rec['id']}  {rec.get('subDomain', '') or '@':30s}  "
        f"{rec['fieldType']:8s}  TTL={rec.get('ttl', 0):>6}  "
        f"{rec.get('target', '')}"
    )


# ── Commands ─────────────────────────────────────────────────────────────────

def cmd_list(args):
    client = get_client()
    ids = api_call(client, "get", f"/domain/zone/{args.domain}/record")
    print(f"Domain: {args.domain}  ({len(ids)} records)\n")
    records = []
    for rid in ids:
        rec = api_call(client, "get", f"/domain/zone/{args.domain}/record/{rid}")
        records.append(rec)
    # Sort by type then subdomain
    records.sort(key=lambda r: (r["fieldType"], r.get("subDomain", "") or ""))
    for rec in records:
        print(format_record(rec))


def cmd_get(args):
    client = get_client()
    params = {"fieldType": args.type}
    if args.name:
        params["subDomain"] = args.name
    ids = api_call(client, "get", f"/domain/zone/{args.domain}/record", **params)
    if not ids:
        print("No matching records found.")
        return
    for rid in ids:
        rec = api_call(client, "get", f"/domain/zone/{args.domain}/record/{rid}")
        print(format_record(rec))


def cmd_add(args):
    client = get_client()
    # Auto-backup before mutation
    path, _ = backup_domain(client, args.domain)
    print(f"Backup saved: {path}")

    payload = {
        "fieldType": args.type,
        "subDomain": args.name,
        "target": args.value,
    }
    if args.ttl is not None:
        payload["ttl"] = args.ttl

    result = api_call(client, "post", f"/domain/zone/{args.domain}/record", **payload)
    log_mutation(args.domain, "add", record_id=result.get("id"), new_value=payload)
    print(f"Record added:")
    print(format_record(result))
    print(f"\nRun 'ovh-dns refresh {args.domain}' to apply changes.")


def cmd_update(args):
    client = get_client()
    # Fetch old value
    old = get_record_detail(client, args.domain, args.record_id)
    # Auto-backup before mutation
    path, _ = backup_domain(client, args.domain)
    print(f"Backup saved: {path}")

    api_call(client, "put", f"/domain/zone/{args.domain}/record/{args.record_id}",
             target=args.value)
    log_mutation(args.domain, "update", record_id=args.record_id,
                 old_value={"target": old.get("target")},
                 new_value={"target": args.value})
    updated = get_record_detail(client, args.domain, args.record_id)
    print(f"Record updated:")
    print(format_record(updated))
    print(f"\nRun 'ovh-dns refresh {args.domain}' to apply changes.")


def cmd_delete(args):
    client = get_client()
    rec = get_record_detail(client, args.domain, args.record_id)

    if not args.yes:
        print("Would delete:")
        print(format_record(rec))
        print(f"\nRe-run with --yes to confirm deletion.")
        return

    # Auto-backup before mutation
    path, _ = backup_domain(client, args.domain)
    print(f"Backup saved: {path}")

    api_call(client, "delete", f"/domain/zone/{args.domain}/record/{args.record_id}")
    log_mutation(args.domain, "delete", record_id=args.record_id, old_value=rec)
    print(f"Record {args.record_id} deleted.")
    print(f"\nRun 'ovh-dns refresh {args.domain}' to apply changes.")


def cmd_backup(args):
    client = get_client()
    path, records = backup_domain(client, args.domain)
    print(f"Backed up {len(records)} records to: {path}")


def cmd_refresh(args):
    client = get_client()
    api_call(client, "post", f"/domain/zone/{args.domain}/refresh")
    log_mutation(args.domain, "refresh")
    print(f"Zone {args.domain} refreshed — changes are now live.")


# ── CLI ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="ovh-dns",
        description="Safe OVH DNS management CLI",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # list
    p = sub.add_parser("list", help="List all DNS records for a domain")
    p.add_argument("domain")

    # get
    p = sub.add_parser("get", help="Get specific DNS records")
    p.add_argument("domain")
    p.add_argument("type", help="Record type (A, AAAA, CNAME, MX, TXT, ...)")
    p.add_argument("name", nargs="?", default=None, help="Subdomain name filter")

    # add
    p = sub.add_parser("add", help="Add a DNS record")
    p.add_argument("domain")
    p.add_argument("type", help="Record type")
    p.add_argument("name", help="Subdomain name (use '' for root)")
    p.add_argument("value", help="Record target value")
    p.add_argument("--ttl", type=int, default=None, help="TTL in seconds")

    # update
    p = sub.add_parser("update", help="Update a DNS record's target value")
    p.add_argument("domain")
    p.add_argument("record_id", type=int, help="Record ID to update")
    p.add_argument("value", help="New target value")

    # delete
    p = sub.add_parser("delete", help="Delete a DNS record")
    p.add_argument("domain")
    p.add_argument("record_id", type=int, help="Record ID to delete")
    p.add_argument("--yes", action="store_true", help="Confirm deletion")

    # backup
    p = sub.add_parser("backup", help="Backup all records to JSON")
    p.add_argument("domain")

    # refresh
    p = sub.add_parser("refresh", help="Apply pending DNS changes")
    p.add_argument("domain")

    args = parser.parse_args()
    cmd_map = {
        "list": cmd_list,
        "get": cmd_get,
        "add": cmd_add,
        "update": cmd_update,
        "delete": cmd_delete,
        "backup": cmd_backup,
        "refresh": cmd_refresh,
    }
    try:
        cmd_map[args.command](args)
    except ovh.exceptions.ResourceNotFoundError as e:
        print(f"ERROR: Resource not found — {e}", file=sys.stderr)
        sys.exit(1)
    except ovh.exceptions.BadParametersError as e:
        print(f"ERROR: Bad parameters — {e}", file=sys.stderr)
        sys.exit(1)
    except ovh.exceptions.NotGrantedCallError as e:
        print(f"ERROR: API permission denied — {e}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"ERROR: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
