{
  "statusLine": {
    "type": "command",
    "command": "./.claude/hooks/project-context-statusline.sh"
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(bun *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(curl *)",
      "Bash(mem-reason *)",
      "Bash(wa status*)",
      "Bash(wa messages*)",
      "Bash(wa chats*)",
      "Bash(wa transcribe*)",
      "Bash(wa send *)",
      "Bash(fang-msg *)",
      "Bash(~/fang/display/fang-msg *)",
      "Bash(~/fang/display/fang-verify *)",
      "Bash(bash ./.claude/hooks/project-session-end.sh*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/project-session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/project-context-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/project-prod-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/project-db-guard.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/track-agent-lifecycle.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/validate-agent-output.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/project-auto-capture.sh"
          }
        ]
      }
    ],
    "Stop": []
  }
}
