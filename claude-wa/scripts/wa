#!/usr/bin/env bash
# Lightweight WhatsApp CLI - wraps the local HTTP API
set -euo pipefail

BASE="http://127.0.0.1:${WA_PORT:-7777}"
DIR="$(cd "$(dirname "$0")" && pwd)"
FMT="node $DIR/fmt.mjs"

# URL-encode a string (handles Unicode, spaces, special chars)
urlencode() {
  python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1], safe=''))" "${1:-}"
}

# Auto-setup: install deps if needed
if [[ ! -d "$DIR/node_modules" ]]; then
  bash "$DIR/setup.sh"
fi

# Auto-start service if needed (skip for start/stop/log/help)
case "${1:-help}" in
  status|chats|messages|send|media|describe|transcribe|export|fetch-history|watermarks)
    if ! curl -s --max-time 1 "$BASE/status" > /dev/null 2>&1; then
      echo "[claude-wa] Service not running, starting automatically..."
      mkdir -p "$DIR/.data"
      nohup node "$DIR/service.mjs" > "$DIR/.data/service.log" 2>&1 &
      # Wait up to 15s for service to be ready
      for i in $(seq 1 30); do
        if curl -s --max-time 1 "$BASE/status" > /dev/null 2>&1; then
          echo "[claude-wa] Service ready."
          break
        fi
        if [[ $i -eq 30 ]]; then
          echo "[claude-wa] ERROR: Service failed to start. Check: tail $DIR/.data/service.log"
          exit 1
        fi
        sleep 0.5
      done
    fi
    ;;
esac

case "${1:-help}" in
  status)
    curl -s "$BASE/status" | $FMT status
    ;;
  chats)
    curl -s "$BASE/chats" | $FMT chats
    ;;
  messages)
    shift
    PARAMS=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --chat|--since|--limit|--search)
          if [[ $# -lt 2 ]]; then echo "Error: $1 requires a value"; exit 1; fi
          KEY="${1#--}"
          PARAMS+="&${KEY}=$(urlencode "$2")"; shift 2 ;;
        *) shift ;;
      esac
    done
    curl -s "$BASE/messages?${PARAMS#&}" | $FMT messages
    ;;
  send)
    shift
    CHAT="${1:-}"
    if [[ -z "$CHAT" ]]; then echo "Usage: wa send <chat> <message text>"; exit 1; fi
    shift
    TEXT="$*"
    if [[ -z "$TEXT" ]]; then echo "Usage: wa send <chat> <message text>"; exit 1; fi
    PAYLOAD=$(python3 -c "import json,sys; print(json.dumps({'chat': sys.argv[1], 'text': sys.argv[2]}))" "$CHAT" "$TEXT")
    curl -s -X POST "$BASE/send" \
      -H 'Content-Type: application/json' \
      -d "$PAYLOAD" | $FMT send
    ;;
  fetch-history)
    shift
    PARAMS=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --chat|--count)
          if [[ $# -lt 2 ]]; then echo "Error: $1 requires a value"; exit 1; fi
          KEY="${1#--}"
          PARAMS+="&${KEY}=$(urlencode "$2")"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [[ -z "$PARAMS" ]] || [[ "$PARAMS" != *"chat="* ]]; then
      echo "Usage: wa fetch-history --chat <name> [--count N]"
      echo "  Requests older message history from WhatsApp servers."
      echo "  History arrives asynchronously — wait a few seconds then query: wa messages --chat <name>"
      exit 1
    fi
    curl -s "$BASE/fetch-history?${PARAMS#&}"
    ;;
  watermarks)
    curl -s "$BASE/watermarks" | python3 -m json.tool
    ;;
  media|describe)
    shift
    ID="${1:-}"
    if [[ -z "$ID" ]]; then echo "Usage: wa media <message_id>"; exit 1; fi
    curl -s "$BASE/media?id=$ID" | $FMT media
    ;;
  transcribe)
    shift
    ID="${1:-}"
    if [[ -z "$ID" ]]; then echo "Usage: wa transcribe <message_id>"; exit 1; fi
    curl -s --max-time 600 "$BASE/transcribe?id=$ID" | $FMT transcribe
    ;;
  export)
    shift
    PARAMS=""
    TRANSCRIBE=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --chat|--since|--exclude|--include)
          if [[ $# -lt 2 ]]; then echo "Error: $1 requires a value"; exit 1; fi
          KEY="${1#--}"
          PARAMS+="&${KEY}=$(urlencode "$2")"; shift 2 ;;
        --transcribe)  TRANSCRIBE="&transcribe=1"; shift ;;
        *) shift ;;
      esac
    done
    if [[ -z "$PARAMS" ]] || [[ "$PARAMS" != *"chat="* ]]; then
      echo "Usage: wa export --chat <name> [--exclude image,video] [--include voice,text] [--transcribe] [--since 7d]"
      exit 1
    fi
    curl -s --max-time 600 "$BASE/export?${PARAMS#&}${TRANSCRIBE}"
    ;;
  start)
    if pgrep -f "node $DIR/service.mjs" > /dev/null 2>&1; then
      echo "Already running ($(pgrep -f "node $DIR/service.mjs"))"
    else
      mkdir -p "$DIR/.data"
      nohup node "$DIR/service.mjs" > "$DIR/.data/service.log" 2>&1 &
      echo "Started (PID $!). Scan QR: tail -f $DIR/.data/service.log"
    fi
    ;;
  stop)
    pkill -f "node $DIR/service.mjs" 2>/dev/null && echo "Stopped" || echo "Not running"
    ;;
  log)
    tail -f "$DIR/.data/service.log"
    ;;
  help|*)
    echo "Usage: wa <command>"
    echo "  start              Start WhatsApp service (background)"
    echo "  stop               Stop WhatsApp service"
    echo "  log                Tail service log (QR code appears here)"
    echo "  status             Connection status"
    echo "  chats              List recent chats"
    echo "  messages [opts]    Fetch messages"
    echo "    --chat <jid>       Filter by chat (partial match)"
    echo "    --since <10m|1h>   Time window"
    echo "    --limit <N>        Max messages (default 50)"
    echo "    --search <text>    Search message body"
    echo "  send <chat> <text> Send a message"
    echo "  watermarks         Show per-conversation read watermarks"
    echo "  fetch-history [opts] Request older history from WhatsApp"
    echo "    --chat <name>      Chat name or JID (required)"
    echo "    --count <N>        Number of messages to request (default 100)"
    echo "  media <id>         Download media file"
    echo "  describe <id>      Download image (alias for media)"
    echo "  transcribe <id>    Transcribe voice/audio/video"
    echo "  export [opts]      Export conversation with auto-transcription"
    echo "    --chat <name>      Chat name (partial match, required)"
    echo "    --exclude <types>  Exclude media types (e.g. image,video)"
    echo "    --include <types>  Only include these types (e.g. voice,text)"
    echo "    --transcribe       Auto-transcribe voice/audio/video"
    echo "    --since <10m|7d>   Time window"
    ;;
esac
